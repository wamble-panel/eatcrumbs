# Backend API URL (your deployed backend on Vercel)
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Supabase (for Realtime order tracking — use the anon/public key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Franchise slug fallback — used in local dev when subdomain routing isn't available.
# In production the slug is read from the subdomain (e.g. cairo.prepit.app → "cairo").
NEXT_PUBLIC_FRANCHISE_SLUG=demo
