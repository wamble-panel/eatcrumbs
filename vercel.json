{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "admin.eg.prepit.app/**",
      "use": "@vercel/static"
    },
    {
      "src": "customer_example_sided_website/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/admin(.*)",
      "dest": "/admin.eg.prepit.app$1"
    },
    {
      "src": "/(.*)",
      "dest": "/customer_example_sided_website/$1"
    }
  ]
}
