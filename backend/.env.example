# Server
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ADMIN_SECRET=change_me_to_a_different_long_random_secret
JWT_EXPIRES_IN=7d
JWT_CUSTOMER_EXPIRES_IN=30d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Paymob
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_CURRENCY=EGP

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=noreply@prepit.app

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Foodics
FOODICS_CLIENT_ID=
FOODICS_CLIENT_SECRET=
FOODICS_REDIRECT_URI=https://admin.prepit.app/foodics/callback
FOODICS_LOYALTY_REDIRECT_URI=https://admin.prepit.app/foodics/loyalty/callback
FOODICS_SANDBOX=false

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Vercel
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# Redis (optional — rate limiting falls back to in-memory)
REDIS_URL=

# Frontend URLs (comma-separated allowed origins)
ALLOWED_ORIGINS=https://admin.prepit.app,https://*.prepit.app

# Pelias Geocoding
PELIAS_API_URL=https://pilias.eg.prepit.app/v1

# Backend public URL (used for OAuth callbacks)
BACKEND_URL=https://api.eg.l.prepits.com

# Frontend URLs
ADMIN_FRONTEND_URL=https://admin.prepit.app
CUSTOMER_FRONTEND_URL=https://prepit.app
